rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuth() && (request.auth.uid == resource.data.ownerId || isAdmin());
      allow delete: if isAuth() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
    }

    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if isAuth();
    }
  }
}
